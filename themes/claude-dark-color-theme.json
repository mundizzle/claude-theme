  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6b6a65",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#788c5d"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language", "constant.character"],
      "settings": {
        "foreground": "#c08c3a"
      }
    },
    {
      "scope": ["constant.other", "constant.other.color"],
      "settings": {
        "foreground": "#d97757"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#d97757"
      }
    },
    {
      "scope": ["keyword.control", "keyword.operator"],
      "settings": {
        "foreground": "#d97757"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#c08c3a"
      }
    },
    {
      "scope": ["entity.name.class", "entity.name.type", "support.class", "support.type"],
      "settings": {
        "foreground": "#6a9b91"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#d97757"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#c08c3a"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": {
        "foreground": "#9588a8"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#d97757",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.constant", "support.variable"],
      "settings": {
        "foreground": "#6a9b91"
      }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": {
        "foreground": "#6b6a65"
      }
    },
    {
      "scope": ["meta.function-call"],
      "settings": {
        "foreground": "#c08c3a"
      }
    },
    {
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#6a9b91"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#d97757",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#788c5d"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#6b6a65",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#c08c3a"
      }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#6a9bcc"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#EF4444"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#c08c3a",
        "fontStyle": "strikethrough"
      }
    }
  ]
}
